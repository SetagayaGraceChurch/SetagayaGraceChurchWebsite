---
import "../styles/index.css";

export interface Props {
  title: string;
  description: string;
  path?: string;
  image?: string;
}

const { title, description, path = Astro.url.pathname, image } = Astro.props;
const canonical = new URL(path, Astro.site ?? Astro.url.origin);
const imageUrl = image ? new URL(image, Astro.site ?? Astro.url.origin) : null;
const shouldIndex = import.meta.env.PUBLIC_INDEX_SITE === "true";
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="canonical" href={canonical.href} />
    <meta name="robots" content={shouldIndex ? "index,follow" : "noindex,nofollow"} />
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:site_name" content="世田谷グレースチャーチ" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical.href} />
    {imageUrl ? <meta property="og:image" content={imageUrl.href} /> : null}
    {imageUrl ? <meta property="og:image:alt" content="世田谷グレースチャーチの入口" /> : null}
    <meta name="twitter:card" content="summary_large_image" />
    {imageUrl ? <meta name="twitter:image" content={imageUrl.href} /> : null}
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
